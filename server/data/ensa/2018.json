            { "label": "B", "fr": "$1$" },
            { "label": "C", "fr": "$-\\infty$" },
            { "label": "D", "fr": "$+\\infty$" }
          ],
          "correctIndex": 0,
          "explanation_fr": "Fonctions bornées. $-\\frac{1}{n} \\le \\frac{\\sin^2 n - \\cos^3 n}{n} \\le \\frac{2}{n}$. Limite $0$ par le théorème des gendarmes.",
          "topics": ["suites", "limites"],
          "difficulty": "facile"
        },
