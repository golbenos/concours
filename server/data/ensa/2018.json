        {
          "id": 1,
          "question_fr": "Soit $(u_n)$ une suite réelle. Si $\\lim(u_{n+1}-u_n)=2$, alors $\\lim u_n/n =$",
          "choices": [
            { "label": "A", "fr": "$0$" },
            { "label": "B", "fr": "$1$" },
            { "label": "C", "fr": "$+\\infty$" },
            { "label": "D", "fr": "$2$" }
          ],
          "correctIndex": 3,
          "explanation_fr": "Théorème de Césaro : $\\lim\\frac{u_n}{n}=2$.",
          "topics": ["suites"],
          "difficulty": "moyen"
        },
        {
          "id": 2,
          "question_fr": "$\\lim_{n\\to+\\infty} \\frac{\\sin^2 n - \\cos^3 n}{n} =$",
